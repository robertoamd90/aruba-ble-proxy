# Runtime configuration for the standalone Aruba BLE receiver.
#
# Copy to .env for local use, then export it before running:
# set -a
# source .env
# set +a

ARUBA_BLE_PROXY_HOST=0.0.0.0
ARUBA_BLE_PROXY_PORT=7443
ARUBA_BLE_PROXY_ACCESS_TOKEN=
ARUBA_BLE_PROXY_LOG_LEVEL=info
ARUBA_BLE_PROXY_SUMMARY=false
